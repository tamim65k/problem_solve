void solve() {
    int n,k;cin>>n>>k;
    bool found=0;
    for (int i = 1; i <= n; i++) {
        int c;cin>>c;
        if (c==k) found=1;
    }
    if (found==0) cout<<"NO"<<endl;
    else cout<<"YES"<<endl;
}
 
